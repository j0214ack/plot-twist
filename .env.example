# Copy this file to .env.local. Never commit the real key.
OPENAI_API_KEY=

# Fast is the playable default (Luna + low). Quality uses Sol + medium.
SPELL_GENERATION_MODE=fast

# Optional overrides used by both live evals and the local spell endpoint.
OPENAI_MODEL=
OPENAI_REASONING_EFFORT=

# Optional paid latency tier. Leave empty for standard processing.
OPENAI_SERVICE_TIER=

# Speech-to-text model used by push-to-talk incantations.
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe

# Public preview only. Keep these server-side and omit DEMO_ACCESS_CODE on Demo Day.
# ALLOWED_ORIGIN=https://your-app.fly.dev
# DEMO_SESSION_SECRET=
# DEMO_ACCESS_CODE=
