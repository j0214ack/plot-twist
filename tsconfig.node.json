{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true
  },
  "include": [
    "vite.config.ts",
    "server",
    "evals",
    "pocs/leave-the-door-open/src/**/*.ts",
    "src/game/**/*.ts",
    "src/generative/**/*.ts"
  ],
  "exclude": ["**/*.test.ts"]
}
