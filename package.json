{
  "name": "the-unwritten-spell",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "vite preview --host 0.0.0.0 --port 8080 --strictPort",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval:live": "tsx evals/run-live.ts",
    "eval:ldo-live": "tsx pocs/leave-the-door-open/src/run-live-validation.ts",
    "eval:ldo-replay": "tsx pocs/leave-the-door-open/src/run-saved-state-replay.ts",
    "play:ldo": "npm run play:ldo:text",
    "play:ldo:text": "tsx pocs/leave-the-door-open/src/run-terminal-playtest.ts",
    "play:ldo:web": "vite --mode ldo-local-codex --open /leave-the-door-open/ --port 5173 --strictPort"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "openai": "^6.46.0",
    "three": "^0.178.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/three": "^0.178.1",
    "tsx": "^4.23.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
